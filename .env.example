# ── Server ─────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info

# ── YouTube ────────────────────────────────────────────
# Informe o channelId OU o liveId de uma live em andamento
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_LIVE_ID=

# Reconexão automática
YT_RECONNECT_DELAY_MS=5000
YT_MAX_RECONNECT_ATTEMPTS=10

# ── Discord ────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
# IDs de canais a monitorar (separados por vírgula)
DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432
# IDs de guilds permitidos (opcional, deixar vazio para todos)
DISCORD_GUILD_IDS=

# ── Circuit Breaker ────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_MS=30000
